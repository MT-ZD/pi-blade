{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@pi-blade/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
